<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#111827" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="CalorieTrack" />
  <link rel="manifest" href="manifest.json" />
  <link rel="apple-touch-icon" href="icons/icon-180.png" />
  <title>CalorieTrack</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <div class="app-shell">
    <header class="topbar">
      <div>
        <p class="eyebrow" id="todayDate">Today</p>
        <h1>CalorieTrack</h1>
      </div>
      <button class="icon-button" id="backupButton" title="Export backup">↥</button>
    </header>

    <main>
      <section class="screen active" id="screen-today" aria-labelledby="todayTab">
        <div class="hero-card">
          <div class="hero-row">
            <div>
              <p class="label">Eaten today</p>
              <div class="big-number"><span id="todayCalories">0</span><span> kcal</span></div>
            </div>
            <div class="ring" aria-hidden="true">
              <svg viewBox="0 0 120 120">
                <circle class="ring-bg" cx="60" cy="60" r="52"></circle>
                <circle class="ring-progress" id="progressCircle" cx="60" cy="60" r="52"></circle>
              </svg>
              <span id="progressPercent">0%</span>
            </div>
          </div>
          <div class="metrics-grid">
            <div>
              <p class="label">Target</p>
              <strong><span id="targetCalories">0</span> kcal</strong>
            </div>
            <div>
              <p class="label">Remaining</p>
              <strong id="remainingCalories">0 kcal</strong>
            </div>
            <div>
              <p class="label">Protein</p>
              <strong><span id="todayProtein">0</span>g</strong>
            </div>
            <div>
              <p class="label">Carbs / fat</p>
              <strong><span id="todayCarbs">0</span>g / <span id="todayFat">0</span>g</strong>
            </div>
          </div>
        </div>

        <button class="primary-button" data-open-modal="foodModal">+ Add food</button>

        <section class="card">
          <div class="section-heading">
            <h2>Meals today</h2>
            <button class="text-button" id="clearTodayButton">Clear</button>
          </div>
          <div id="todayEntries" class="entry-list empty-state">No food added yet.</div>
        </section>
      </section>

      <section class="screen" id="screen-foods" aria-labelledby="foodsTab">
        <section class="card">
          <div class="section-heading">
            <h2>Saved foods</h2>
            <button class="text-button" data-open-modal="savedFoodModal">+ New</button>
          </div>
          <p class="muted">Tap a saved food to add it to today.</p>
          <div id="savedFoods" class="entry-list empty-state"></div>
        </section>
      </section>

      <section class="screen" id="screen-weight" aria-labelledby="weightTab">
        <div class="hero-card">
          <p class="label">Latest weight</p>
          <div class="big-number"><span id="latestWeight">—</span><span id="weightUnitHero"> kg</span></div>
          <div class="metrics-grid">
            <div>
              <p class="label">Estimated BMR</p>
              <strong><span id="bmrValue">0</span> kcal</strong>
            </div>
            <div>
              <p class="label">Maintenance</p>
              <strong><span id="tdeeValue">0</span> kcal</strong>
            </div>
            <div>
              <p class="label">7-day change</p>
              <strong id="weightTrend">—</strong>
            </div>
            <div>
              <p class="label">Goal target</p>
              <strong><span id="goalTargetWeight">0</span> kcal</strong>
            </div>
          </div>
        </div>

        <button class="primary-button" data-open-modal="weightModal">+ Add weight</button>

        <section class="card">
          <div class="section-heading">
            <h2>Weight history</h2>
            <button class="text-button" id="clearWeightsButton">Clear</button>
          </div>
          <div id="weightEntries" class="entry-list empty-state">No weight entries yet.</div>
        </section>
      </section>

      <section class="screen" id="screen-settings" aria-labelledby="settingsTab">
        <section class="card">
          <h2>Your settings</h2>
          <form id="settingsForm" class="form-grid">
            <label>Age
              <input id="age" type="number" inputmode="numeric" min="1" placeholder="e.g. 25" />
            </label>
            <label>Sex
              <select id="sex">
                <option value="male">Male</option>
                <option value="female">Female</option>
              </select>
            </label>
            <label>Height, cm
              <input id="height" type="number" inputmode="decimal" min="1" placeholder="e.g. 180" />
            </label>
            <label>Weight unit
              <select id="weightUnit">
                <option value="kg">kg</option>
                <option value="lb">lb</option>
              </select>
            </label>
            <label>Activity level
              <select id="activity">
                <option value="1.2">Sedentary</option>
                <option value="1.375">Light activity</option>
                <option value="1.55">Moderate activity</option>
                <option value="1.725">Very active</option>
                <option value="1.9">Athlete-level</option>
              </select>
            </label>
            <label>Goal
              <select id="goal">
                <option value="maintain">Maintain weight</option>
                <option value="cut250">Lose slowly, -250 kcal</option>
                <option value="cut500">Lose faster, -500 kcal</option>
                <option value="bulk250">Gain slowly, +250 kcal</option>
                <option value="bulk500">Gain faster, +500 kcal</option>
                <option value="custom">Custom target</option>
              </select>
            </label>
            <label id="customTargetWrap">Custom daily target
              <input id="customTarget" type="number" inputmode="numeric" min="0" placeholder="e.g. 2300" />
            </label>
            <button class="primary-button" type="submit">Save settings</button>
          </form>
          <p class="muted small-note">BMR is estimated with Mifflin-St Jeor. Maintenance is BMR × activity level. It is an estimate, not a medical measurement.</p>
        </section>

        <section class="card danger-zone">
          <h2>Data</h2>
          <button class="secondary-button" id="importButton">Import backup</button>
          <input id="importInput" type="file" accept="application/json" hidden />
          <button class="danger-button" id="resetButton">Reset all data</button>
        </section>
      </section>
    </main>

    <nav class="bottom-nav" aria-label="Main navigation">
      <button class="nav-item active" id="todayTab" data-screen="today">Today</button>
      <button class="nav-item" id="foodsTab" data-screen="foods">Foods</button>
      <button class="nav-item" id="weightTab" data-screen="weight">Weight</button>
      <button class="nav-item" id="settingsTab" data-screen="settings">Settings</button>
    </nav>
  </div>

  <dialog class="modal" id="foodModal">
    <form method="dialog" class="modal-card" id="foodForm">
      <div class="section-heading">
        <h2>Add food</h2>
        <button class="icon-button" value="cancel" type="button" data-close-modal="foodModal">×</button>
      </div>
      <label>Food name
        <input id="foodName" type="text" required placeholder="e.g. Eggs" />
      </label>
      <div class="two-col">
        <label>Calories
          <input id="foodCalories" type="number" inputmode="numeric" min="0" required placeholder="280" />
        </label>
        <label>Meal
          <select id="mealType">
            <option>Breakfast</option>
            <option>Lunch</option>
            <option>Dinner</option>
            <option>Snack</option>
          </select>
        </label>
      </div>
      <div class="three-col">
        <label>Protein, g
          <input id="foodProtein" type="number" inputmode="decimal" min="0" value="0" />
        </label>
        <label>Carbs, g
          <input id="foodCarbs" type="number" inputmode="decimal" min="0" value="0" />
        </label>
        <label>Fat, g
          <input id="foodFat" type="number" inputmode="decimal" min="0" value="0" />
        </label>
      </div>
      <label class="checkbox-row">
        <input id="saveFoodToo" type="checkbox" /> Save this food for quick add
      </label>
      <button class="primary-button" type="submit">Add to today</button>
    </form>
  </dialog>

  <dialog class="modal" id="savedFoodModal">
    <form method="dialog" class="modal-card" id="savedFoodForm">
      <div class="section-heading">
        <h2>New saved food</h2>
        <button class="icon-button" value="cancel" type="button" data-close-modal="savedFoodModal">×</button>
      </div>
      <label>Food name
        <input id="savedFoodName" type="text" required placeholder="e.g. 250g beef" />
      </label>
      <div class="two-col">
        <label>Calories
          <input id="savedFoodCalories" type="number" inputmode="numeric" min="0" required placeholder="625" />
        </label>
        <label>Default meal
          <select id="savedFoodMeal">
            <option>Breakfast</option>
            <option>Lunch</option>
            <option>Dinner</option>
            <option>Snack</option>
          </select>
        </label>
      </div>
      <div class="three-col">
        <label>Protein, g
          <input id="savedFoodProtein" type="number" inputmode="decimal" min="0" value="0" />
        </label>
        <label>Carbs, g
          <input id="savedFoodCarbs" type="number" inputmode="decimal" min="0" value="0" />
        </label>
        <label>Fat, g
          <input id="savedFoodFat" type="number" inputmode="decimal" min="0" value="0" />
        </label>
      </div>
      <button class="primary-button" type="submit">Save food</button>
    </form>
  </dialog>

  <dialog class="modal" id="weightModal">
    <form method="dialog" class="modal-card" id="weightForm">
      <div class="section-heading">
        <h2>Add weight</h2>
        <button class="icon-button" value="cancel" type="button" data-close-modal="weightModal">×</button>
      </div>
      <label>Weight
        <input id="weightValue" type="number" inputmode="decimal" min="0" step="0.1" required placeholder="82.4" />
      </label>
      <label>Date
        <input id="weightDate" type="date" required />
      </label>
      <button class="primary-button" type="submit">Save weight</button>
    </form>
  </dialog>

  <div id="toast" class="toast" role="status" aria-live="polite"></div>
  <script src="app.js"></script>
</body>
</html>
